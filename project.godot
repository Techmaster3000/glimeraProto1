; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="GLIMERA proto1"
run/main_scene="uid://ynp6rt5ks1hu"
config/features=PackedStringArray("4.6", "C#", "Forward Plus")
run/max_fps=60
config/icon="res://images/icon.svg"

[audio]

buses/default_bus_layout="uid://cbi7bxtx143bl"

[autoload]

Dialogue="*uid://f40fbwgpnkvu"
Dialogic="*uid://ds2q0uclmolvu"
BattleManager="*uid://bks8pyajw4qln"
PlayerManager="*uid://dujbeol33fjtr"
Debug="uid://br2ibcwc8lhs4"
ControllerIcons="*uid://d2cyg24h3ss8r"
GraftGlobals="*uid://ddwa1wyywsuth"
SFXPlayer="*uid://bhojwcno7gi1b"
MusicPlayer="*uid://blpcv03sdkav6"

[dialogic]

directories/dch_directory={
"Gli": "res://characters/Gli.dch",
"skull": "res://characters/skull.dch"
}
directories/dtl_directory={
"Talk with Bob": "res://Dialogue Timelines/Talk with Bob.dtl",
"bedroom": "res://Dialogue Timelines/interactable.dtl",
"events": "res://Dialogue Timelines/events.dtl",
"mid_combat": "res://Dialogue Timelines/mid_combat.dtl",
"timeline": "res://Dialogue Timelines/timeline.dtl"
}
layout/style_directory={
"": "res://Dialogue Timelines/New_File.tres",
"New_File": "res://Dialogue Timelines/New_File.tres",
"myStyle": "res://Dialogue Timelines/myStyle.tres"
}
glossary/default_case_sensitive=true
layout/style_list=["res://Dialogue Timelines/New_File.tres", "res://Dialogue Timelines/myStyle.tres"]
layout/default_style="res://Dialogue Timelines/New_File.tres"
variables={
"event": "",
"have_rope": false,
"have_violin": false,
"quest_1": "default",
"talkedTo": false,
"target": "default"
}
extensions_folder="res://addons/dialogic_additions"
text/letter_speed=0.03
text/initial_text_reveal_skippable=true
text/text_reveal_skip_delay=0.1
text/advance_delay=0.1
text/autoadvance_per_character_delay=0.1
text/autoadvance_ignored_characters_enabled=true
animations/join_default_length=0.5
animations/join_default_wait=true
animations/leave_default_length=0.5
animations/leave_default_wait=true
animations/cross_fade_default_length=0.5
choices/autofocus_first=false
choices/delay=0.2
choices/reveal_delay=0
choices/reveal_by_input=false
save/autosave_delay=60.0
save/encryption_on_exports_only=true
text/input_action="dialogic_default_action"
text/autocolor_names=false
text/autoskip_time_per_event=0.3
text/absolute_autopauses=false
text/autopauses={
"\"?.,!\"": 0.1
}
audio/channel_defaults={
"": {
"audio_bus": "",
"fade_length": 0.0,
"loop": false,
"volume": 0.0
},
"music": {
"audio_bus": "Music",
"fade_length": 0.0,
"loop": true,
"volume": 0.0
}
}
history/simple_history_enabled=true
choices/hotkey_behaviour=1
audio/type_sound_bus="SFX"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=2
window/stretch/mode="viewport"

[dotnet]

project/assembly_name="GLIMERA proto1"

[editor]

movie_writer/video_quality=0.5
movie_writer/ogv/audio_quality=0.04999999999999999
movie_writer/movie_file="C:/Users/MSI/Documents/Godot Engine/Godot Projects/glimeraProto1/video1.avi"
movie_writer/fps=30

[editor_plugins]

enabled=PackedStringArray("res://addons/controller_icons/plugin.cfg", "res://addons/dialogic/plugin.cfg", "res://addons/github_copilot/plugin.cfg")

